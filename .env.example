# ─── AI API Keys ──────────────────────────────────────────────────────────────
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get yours at: https://cloud.google.com/generative-ai
GOOGLE_API_KEY=

# Get yours at: https://fal.ai/dashboard
FAL_API_KEY=

# Get yours at: https://serpapi.com/dashboard
SERPAPI_API_KEY=

# ─── Summary Agent Configuration ─────────────────────────────────────────────
# Model for Call 1 (Input Summary Card) — fast, cheap model recommended
SUMMARY_MODEL=claude-haiku-4-5-20251001
# Model for Call 2 (Image Generation Prompt) — stronger model for richer prompts
PROMPT_MODEL=claude-sonnet-4-6

# ─── Vision Agent Configuration ───────────────────────────────────────────────
# Comma-separated list of vision providers to try in fallback order
# Available: openai, anthropic, google
# Requires API keys above for the providers you list here
VISION_MODELS=openai,anthropic,google

# Per-provider model names — override to use a different model version
# Falls back to the default shown here if the specified model name is invalid
OPENAI_VISION_MODEL=gpt-4o
ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022
GOOGLE_VISION_MODEL=gemini-2.0-flash

# ─── Service URLs (match docker-compose defaults) ─────────────────────────────
FFMPEG_SIDECAR_URL=http://ffmpeg:8001
RENDERER_SIDECAR_URL=http://renderer:8002

# ─── Storage ──────────────────────────────────────────────────────────────────
# Path inside the backend container where run data is stored
CONTENT_DIR=/app/content
