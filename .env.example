# ─── AI API Keys ──────────────────────────────────────────────────────────────
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get yours at: https://fal.ai/dashboard
FAL_API_KEY=

# Get yours at: https://serpapi.com/dashboard
SERPAPI_API_KEY=

# ─── Service URLs (match docker-compose defaults) ─────────────────────────────
FFMPEG_SIDECAR_URL=http://ffmpeg:8001
RENDERER_SIDECAR_URL=http://renderer:8002

# ─── Storage ──────────────────────────────────────────────────────────────────
# Path inside the backend container where run data is stored
CONTENT_DIR=/app/content
